#!name=Ivy的自用脚本
#!desc=一些自己平常用的比较多的脚本/插件，可自行开关对应功能
#!author=VenenoSix24[https://github.com/VenenoSix24]
#!homepage = https://github.com/VenenoSix24/Ivy-Script
#!version=1.0.1
#!date=2026-04-12 13:46:24
#!icon=https://raw.githubusercontent.com/VenenoSix24/Ivy-Script/refs/heads/main/icons/Loon/tasks.png

[Argument]
iios_enable = switch,true,false,tag=iios签到-脚本开关
aliyun_cookie_enable = switch,false,true,tag=阿里云盘 Cookie-获取开关
aliyun_enable = switch,true,false,tag=阿里云盘签到-脚本开关
ampDache_cookie_enable = switch,false,true,tag=高德地图打车 Cookie-获取开关
ampDache_enable = switch,true,false,tag=高德地图打车签到-脚本开关
glados_cookie_enable = switch,false,true,tag=GLaDOS Cookie-获取开关
glados_enable = switch,true,false,tag=GLaDOS签到-脚本开关
mihoyo_cookie_enable = switch,false,true,tag=米游社 Cookie-获取开关
mihoyo_enable = switch,true,false,tag=米游社签到-脚本开关
meituan_cookie_enable = switch,false,true,tag=美团 Cookie-获取开关
meituan_enable = switch,true,false,tag=美团签到-脚本开关
wps_cookie_enable = switch,false,true,tag=WPS Cookie-获取开关
wps_enable = switch,true,false,tag=WPS签到-脚本开关
macat_enable = switch,true,false,tag=马克喵签到-脚本开关

[Script]
cron "10 0 * * *​" script-path=https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/iios_checkin.js, tag=iios签到, enable={iios_enable}

http-request ^https:\/\/(auth|aliyundrive)\.alipan\.com\/v2\/account\/token script-path=https://gist.githubusercontent.com/Sliverkiss/33800a98dcd029ba09f8b6fc6f0f5162/raw/aliyun.js, requires-body=true, timeout=60, tag=阿里云盘 Cookie, enable={aliyun_cookie_enable}

cron "0 11 * * *" script-path=https://gist.githubusercontent.com/Sliverkiss/33800a98dcd029ba09f8b6fc6f0f5162/raw/aliyun.js, timeout=120, tag=阿里云盘签到, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/AliYunDrive.png, enable={aliyun_enable}

cron "12 0 * * *" script-path=https://raw.githubusercontent.com/fmz200/wool_scripts/main/Scripts/macat/macat_signin.js, timeout=120, tag=马克喵签到, img-url=https://raw.githubusercontent.com/fmz200/wool_scripts/main/icons/apps/Macat.png, enable={macat_enable}

http-response ^https?:\/\/(m5(|-zb)|dache)\.amap\.com\/(ws\/yuece\/(act|openapi\/activity\/current)\/query|common\/(alipaymini|wxmini)\?_ENCRYPT=) script-path=https://raw.githubusercontent.com/wf021325/qx/master/task/ampDache.js, requires-body=true, timeout=60, tag=高德地图打车 Cookie, enable={ampDache_cookie_enable}

cron "2 0 * * *" script-path=https://raw.githubusercontent.com/wf021325/qx/master/task/ampDache.js, timeout=120, tag=高德地图打车签到, enable={ampDache_enable}

http-request https:\/\/glados\.rocks\/api\/user\/checkin tag=GLaDOS Cookie, script-path=https://raw.githubusercontent.com/evilbutcher/Quantumult_X/master/check_in/glados/glados.js, enable={glados_cookie_enable}

cron "5 0 * * *" tag=GLaDOS 签到, script-path=https://raw.githubusercontent.com/evilbutcher/Quantumult_X/master/check_in/glados/glados.js, enable={glados_enable}

http-request ^https:\/\/api-takumi.mihoyo.com\/apihub\/api\/getGameList script-path=https://raw.githubusercontent.com/chavyleung/scripts/refs/heads/master/mihoyo/mihoyo.cookie.js, timeout=60, tag=米游社 Cookie, enable={mihoyo_cookie_enable}

cron "15 0 * * *" tag=米游社签到, script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/mihoyo/mihoyo.js, enable={mihoyo_enable}

http-request ^https:\/\/i.meituan.com\/evolve\/signin\/signpost\/ script-path=https://raw.githubusercontent.com/chavyleung/scripts/refs/heads/master/meituan/meituan.cookie.js, requires-body=true, timeout=60, tag=美团 Cookie, enable={meituan_cookie_enable}

cron "20 0 * * *" tag=美团, script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/meituan/meituan.js, enable={meituan_enable}

http-request ^https:\/\/zt.wps.cn\/2018\/docer_check_in\/api\/act_list script-path=https://raw.githubusercontent.com/chavyleung/scripts/refs/heads/master/wps/wps.cookie.js, timeout=60, tag=WPS Cookie, enable={wps_cookie_enable}

cron "25 0 * * *" tag=WPS, script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/wps/wps.js, enable={wps_enable}

[MITM]
hostname = auth.alipan.com, auth.aliyundrive.com, *.amap.com, glados.rocks, api-takumi.mihoyo.com, i.meituan.com, zt.wps.cn